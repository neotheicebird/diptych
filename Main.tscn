[sub_resource type="Shader" id="Shader_thumbnail_spinner"]
code = "shader_type canvas_item;\n\nuniform float thickness = 0.08;\nuniform float softness = 0.02;\nuniform float speed = 0.8;\n\nvec3 hsv2rgb(vec3 c) {\n\tvec3 rgb = clamp(abs(mod(c.x * 6.0 + vec3(0.0, 4.0, 2.0), 6.0) - 3.0) - 1.0, 0.0, 1.0);\n\trgb = rgb * rgb * (3.0 - 2.0 * rgb);\n\treturn c.z * mix(vec3(1.0), rgb, c.y);\n}\n\nvoid fragment() {\n\tvec2 uv = UV * 2.0 - 1.0;\n\tfloat r = length(uv);\n\tfloat angle = atan(uv.y, uv.x);\n\tfloat hue = fract((angle / (2.0 * PI)) + TIME * speed);\n\tvec3 color = hsv2rgb(vec3(hue, 1.0, 1.0));\n\tfloat outer = smoothstep(0.5, 0.5 - softness, r);\n\tfloat inner = smoothstep(0.5 - thickness, 0.5 - thickness - softness, r);\n\tfloat ring = outer * inner;\n\tCOLOR = vec4(color, ring);\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_thumbnail_spinner"]
